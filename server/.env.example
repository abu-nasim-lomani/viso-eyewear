# ── Core ──
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ── Database (MongoDB Atlas) ──
# Create a free cluster at https://www.mongodb.com/atlas, then paste the
# connection string here (remember to add your DB name + URL-encode the password).
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/viso?retryWrites=true&w=majority

# ── Auth ──
# Use a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES=7d

# ── Payment (add when ready — scaffolded, not required for COD) ──
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
